{
  "colors": {
    "ink": { "$type": "color", "$value": "#121417" },
    "near-black": { "$type": "color", "$value": "#141413" },
    "void": { "$type": "color", "$value": "#0F1012" },
    "graphite": { "$type": "color", "$value": "#2D333B" },
    "charcoal-warm": { "$type": "color", "$value": "#3D3D3A" },
    "slate": { "$type": "color", "$value": "#5D6978" },
    "stone": { "$type": "color", "$value": "#87867F" },
    "mist": { "$type": "color", "$value": "#E7EBEF" },
    "parchment": { "$type": "color", "$value": "#F5F4ED" },
    "ivory": { "$type": "color", "$value": "#FAF9F5" },
    "paper": { "$type": "color", "$value": "#F8F7F3" },
    "porcelain": { "$type": "color", "$value": "#FFFFFF" },
    "terracotta": { "$type": "color", "$value": "#C96442" },
    "terracotta-dark": { "$type": "color", "$value": "#9F442B" },
    "focus-blue": { "$type": "color", "$value": "#3898EC" },
    "mint": { "$type": "color", "$value": "#25A784" },
    "amber": { "$type": "color", "$value": "#B7791F" },
    "coral": { "$type": "color", "$value": "#D84E3F" },
    "violet": { "$type": "color", "$value": "#6E56CF" },
    "dark-surface": { "$type": "color", "$value": "#1F2228" },
    "dark-border": { "$type": "color", "$value": "rgba(255,255,255,0.10)" },
    "dark-border-strong": { "$type": "color", "$value": "rgba(255,255,255,0.20)" }
  },
  "modes": {
    "light": {
      "background": "{colors.parchment}",
      "surface": "{colors.ivory}",
      "surface-raised": "{colors.porcelain}",
      "text-primary": "{colors.near-black}",
      "text-secondary": "{colors.charcoal-warm}",
      "text-muted": "{colors.stone}",
      "border": "{colors.mist}",
      "accent": "{colors.terracotta}"
    },
    "dark": {
      "background": "{colors.void}",
      "surface": "{colors.dark-surface}",
      "surface-raised": "rgba(255,255,255,0.03)",
      "text-primary": "rgba(255,255,255,1)",
      "text-secondary": "rgba(255,255,255,0.70)",
      "text-muted": "rgba(255,255,255,0.50)",
      "border": "{colors.dark-border}",
      "border-strong": "{colors.dark-border-strong}",
      "accent": "{colors.terracotta}"
    }
  },
  "typography": {
    "display": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter, ui-sans-serif, system-ui, sans-serif",
        "fontSize": "40px",
        "fontWeight": 720,
        "lineHeight": 1.05,
        "letterSpacing": 0
      }
    },
    "body": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter, ui-sans-serif, system-ui, sans-serif",
        "fontSize": "15px",
        "fontWeight": 400,
        "lineHeight": 1.55,
        "letterSpacing": 0
      }
    },
    "mono": {
      "$type": "typography",
      "$value": {
        "fontFamily": "JetBrains Mono, SFMono-Regular, Consolas, monospace",
        "fontSize": "13px",
        "fontWeight": 500,
        "lineHeight": 1.5,
        "letterSpacing": 0
      }
    }
  },
  "rounded": {
    "xs": { "$type": "dimension", "$value": "4px" },
    "sm": { "$type": "dimension", "$value": "6px" },
    "md": { "$type": "dimension", "$value": "8px" },
    "lg": { "$type": "dimension", "$value": "12px" },
    "full": { "$type": "dimension", "$value": "9999px" }
  },
  "spacing": {
    "xs": { "$type": "dimension", "$value": "4px" },
    "sm": { "$type": "dimension", "$value": "8px" },
    "md": { "$type": "dimension", "$value": "12px" },
    "lg": { "$type": "dimension", "$value": "16px" },
    "xl": { "$type": "dimension", "$value": "24px" },
    "xxl": { "$type": "dimension", "$value": "32px" }
  }
}
